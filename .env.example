# ============================================================
# embedded-device-agent 环境变量示例（占位符，可提交到仓库）
# 复制为 .env 后填入真实值：cp .env.example .env
# .env 已被 .gitignore 忽略，请勿提交真实密钥。
# ============================================================

# ---- LLM 相关 ----
# Anthropic API Key（AnthropicProvider 使用）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API Key（OpenAIProvider / OpenAICompatibleProvider 使用）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI 兼容网关地址（内网/自建 OpenAI 兼容网关时填写；官方 OpenAI 可留空）
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- 串口 / 设备相关 ----
# 设备串口路径（Linux 常见 /dev/ttyUSB0 或 /dev/ttyACM0；macOS 形如 /dev/tty.usbserial-xxxx）
DEVICE_SERIAL_PORT=/dev/ttyUSB0

# 串口波特率（需 <= config 中的 max_safe_baud，否则连接前会被拒绝）
DEVICE_BAUD=921600
